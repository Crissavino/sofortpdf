APP_NAME=sofortpdf
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sofortpdf.com
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

LOG_CHANNEL=stack
LOG_LEVEL=error

# DB compartida con conversie-pdf y contract-kit
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=avocode_production
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=sofortpdf_session

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sofortpdf.com
MAIL_FROM_NAME="sofortpdf.com"

# Stripe (mismo account Avocode — productos con prefijo sofortpdf_)
STRIPE_KEY=pk_live_
STRIPE_SECRET=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# Pricing
TRIAL_PRICE_EUR=1.50
TRIAL_DAYS=2
SUBSCRIPTION_PRICE_EUR=39.99
SUBSCRIPTION_INTERVAL=month
STRIPE_TRIAL_PRICE_ID=price_
STRIPE_SUBSCRIPTION_PRICE_ID=price_

# Conversion service
CONVERSION_SERVICE_URL=http://localhost:8001
CONVERSION_SERVICE_TOKEN=
CONVERSION_SERVICE_ENABLED=false

# Feature flags herramientas
TOOL_MERGE_ENABLED=true
TOOL_COMPRESS_ENABLED=true
TOOL_JPG_TO_PDF_ENABLED=true
TOOL_PDF_TO_WORD_ENABLED=true
TOOL_WORD_TO_PDF_ENABLED=true
TOOL_PDF_TO_JPG_ENABLED=true
TOOL_SPLIT_ENABLED=true
TOOL_EDIT_ENABLED=false
TOOL_SIGN_ENABLED=true
TOOL_PDF_TO_EXCEL_ENABLED=false
TOOL_EXCEL_TO_PDF_ENABLED=false
TOOL_ROTATE_ENABLED=true
TOOL_PROTECT_ENABLED=false
TOOL_UNLOCK_ENABLED=true
TOOL_WATERMARK_ENABLED=true
TOOL_PAGE_NUMBERS_ENABLED=false
TOOL_PDF_TO_PPT_ENABLED=true
TOOL_PPT_TO_PDF_ENABLED=true
TOOL_PDF_TO_PNG_ENABLED=true
TOOL_PNG_TO_PDF_ENABLED=true
TOOL_OCR_ENABLED=true
TOOL_REMOVE_PAGES_ENABLED=true
TOOL_EXTRACT_PAGES_ENABLED=true
TOOL_HTML_TO_PDF_ENABLED=false
TOOL_OPTIMIZE_ENABLED=true

# Archivos temporales
MAX_UPLOAD_SIZE_MB=50
TEMP_FILE_TTL_HOURS=1
DOWNLOAD_LINK_TTL_HOURS=24

# Google Ads (completar al configurar cuenta)
GOOGLE_ADS_TAG_ID=
GOOGLE_ADS_CONVERSION_ID=

# VAD Router (compañía operadora por país)
# WEBSITE_ID es la fila de sofortpdf en la tabla `websites` del DB compartido
WEBSITE_ID=
# Compañía por defecto cuando no hay rules / DB inaccesible
# 1 = AVOCODE (Romania, EU)  3 = JACKCODE (UAE)
DEFAULT_COMPANY_ID=1
DEFAULT_COMPANY_ID_EU=1
DEFAULT_COMPANY_ID_REST=3
# Geo-IP providers (opcional, en cascada)
IPDATA_KEY=
IPINFO_KEY=

# Marca compartida entre profiles
COMPANY_EMAIL=info@sofortpdf.com
COMPANY_WEBSITE=sofortpdf.com
